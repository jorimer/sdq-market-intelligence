# ─── Application ───
ENVIRONMENT=development
APP_NAME="SDQ Market Intelligence"
APP_VERSION=1.0.0

# ─── Database ───
# Local development (SQLite)
DATABASE_URL=sqlite:///./data/sdq_market_intel.db
# Production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Authentication ───
JWT_SECRET_KEY=cambiar-en-produccion-usar-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Anthropic Claude API ───
ANTHROPIC_API_KEY=sk-ant-api03-tu-key-aqui
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── SIB (Superintendencia de Bancos) ───
SIB_API_BASE_URL=https://apis.sb.gob.do
SIB_API_TIMEOUT=30

# ─── Redis (opcional, para cache) ───
REDIS_URL=redis://localhost:6379/0

# ─── Reports ───
REPORTS_DIR=./data/reports
MODELS_DIR=./data/models
CHARTS_DIR=./data/charts

# ─── CORS ───
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ─── Misc ───
DEFAULT_LANGUAGE=es
DEBUG=false

# ─── Railway (solo en produccion) ───
# PORT=8000  # Railway asigna esto automaticamente
# RAILWAY_ENVIRONMENT=production
